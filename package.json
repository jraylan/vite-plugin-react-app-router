{
  "name": "vite-plugin-react-app-router",
  "version": "0.1.9",
  "description": "Vite plugin that brings Next.js App Router file-based routing to standard React projects",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jraylan/vite-plugin-react-app-router.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./types": {
      "types": "./dist/virtual-module.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "types": [
        "./dist/virtual-module.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "scripts",
    "src/virtual-module.d.ts"
  ],
  "scripts": {
    "build": "npx tsc",
    "postbuild": "node scripts/postbuild.mjs",
    "dev": "npx tsc --watch",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "react",
    "router",
    "app-router",
    "next.js",
    "file-based-routing"
  ],
  "author": "jraylan",
  "license": "MIT",
  "devDependencies": {
    "@types/babel__generator": "^7.27.0"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-router-dom": "^6 || ^7",
    "typescript": "^5 || ^6",
    "vite": "^6 || ^7 || ^8"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/generator": "^7.28.6",
    "@babel/types": "^7.28.6"
  }
}
